// Lab Escape — database schema
// PostgreSQL via Prisma 7. Connection URL lives in prisma.config.ts.

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Identity & auth
// ─────────────────────────────────────────────────────────────

enum Role {
  PLAYER
  EDUCATOR
  RESEARCHER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  role          Role      @default(PLAYER)
  institutionId String?
  xp            Int       @default(0)
  level         Int       @default(1)
  streakDays    Int       @default(0)
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institution      Institution?      @relation(fields: [institutionId], references: [id])
  accounts         Account[]
  authSessions     AuthSession[]
  gameSessions     GameSession[]
  achievements     UserAchievement[]
  settings         UserSettings?
  consents         Consent[]
  cognitiveScores  CognitiveScore[]
  exports          DataExport[]
  favoriteRooms    Favorite[]

  @@index([email])
  @@index([institutionId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Institution {
  id        String   @id @default(cuid())
  name      String
  domain    String?  @unique
  seats     Int      @default(50)
  plan      String   @default("education")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  studies Study[]
}

// ─────────────────────────────────────────────────────────────
// Content: labs, rooms, experiments
// ─────────────────────────────────────────────────────────────

enum Difficulty {
  INTRO
  STANDARD
  ADVANCED
}

enum ExperimentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// A wing of the research facility (e.g. Attention, Memory).
model Wing {
  id       String @id @default(cuid())
  slug     String @unique
  name     String
  ordinal  Int
  mapX     Int    @default(0)
  mapY     Int    @default(0)
  rooms    Room[]
}

/// A single escape room built around one experiment paradigm.
model Room {
  id               String           @id @default(cuid())
  slug             String           @unique
  code             String           @unique // e.g. "A-01"
  title            String
  domain           String // e.g. "Selective Attention"
  paradigm         String // e.g. "Inattentional blindness"
  engine           String // which game engine renders it: "stroop" | "nback" | "attention" | ...
  summary          String
  concept          String
  background       String // scientific background, markdown
  difficulty       Difficulty       @default(STANDARD)
  durationMin      Int              @default(12)
  status           ExperimentStatus @default(PUBLISHED)
  ordinal          Int              @default(0)
  wingId           String
  unlockAfterId    String?          @unique
  learningGoals    Json // string[]
  skills           Json // string[]
  originalStudy    Json // { year, researchers[], citation, sample, finding }
  applications     Json // string[]
  config           Json // engine-specific parameters
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  wing         Wing          @relation(fields: [wingId], references: [id])
  unlockAfter  Room?         @relation("UnlockChain", fields: [unlockAfterId], references: [id])
  unlocks      Room?         @relation("UnlockChain")
  sessions     GameSession[]
  achievements Achievement[]
  favorites    Favorite[]

  @@index([wingId])
  @@index([status, ordinal])
}

model Favorite {
  userId    String
  roomId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([userId, roomId])
}

// ─────────────────────────────────────────────────────────────
// Play: sessions, trials, scores
// ─────────────────────────────────────────────────────────────

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model GameSession {
  id          String        @id @default(cuid())
  userId      String
  roomId      String
  status      SessionStatus @default(IN_PROGRESS)
  seed        Int // deterministic trial sequence seed
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  durationMs  Int?
  score       Int?
  accuracy    Float?
  meanRtMs    Float?
  rtCvPct     Float? // RT coefficient of variation — engagement index
  hintsUsed   Int           @default(0)
  studyId     String?
  anonymous   Boolean       @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  room   Room    @relation(fields: [roomId], references: [id])
  study  Study?  @relation(fields: [studyId], references: [id])
  trials Trial[]

  @@index([userId, status])
  @@index([roomId])
  @@index([studyId])
}

/// One stimulus–response pair inside a session. The atomic research record.
model Trial {
  id         String   @id @default(cuid())
  sessionId  String
  index      Int
  phase      String   @default("main") // "practice" | "main"
  stimulus   Json // engine-specific stimulus descriptor
  expected   String?
  response   String?
  correct    Boolean?
  rtMs       Int?
  shownAt    DateTime @default(now())

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, index])
  @@index([sessionId])
}

/// Longitudinal cognitive profile snapshots (one row per user/dimension/day).
model CognitiveScore {
  id        String   @id @default(cuid())
  userId    String
  dimension String // "working_memory" | "attention" | "decision_making" | ...
  value     Float // 0–100 normalized
  sampleN   Int      @default(1)
  date      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dimension, date])
  @@index([userId, dimension])
}

// ─────────────────────────────────────────────────────────────
// Achievements
// ─────────────────────────────────────────────────────────────

model Achievement {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String
  criterion   Json // machine-checkable rule
  xpReward    Int     @default(50)
  roomId      String?
  secret      Boolean @default(false)

  room  Room?             @relation(fields: [roomId], references: [id])
  users UserAchievement[]
}

model UserAchievement {
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
}

// ─────────────────────────────────────────────────────────────
// Research
// ─────────────────────────────────────────────────────────────

/// A configured research study run by an institution (cohort of participants).
model Study {
  id            String   @id @default(cuid())
  institutionId String
  name          String
  description   String?
  joinCode      String   @unique
  roomSlugs     Json // string[] — which rooms are in the protocol
  config        Json // overrides: trial counts, timing, anonymization
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution   @relation(fields: [institutionId], references: [id])
  sessions    GameSession[]
  consents    Consent[]

  @@index([institutionId])
}

model Consent {
  id        String   @id @default(cuid())
  userId    String
  studyId   String
  version   String
  grantedAt DateTime @default(now())
  revokedAt DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  study Study @relation(fields: [studyId], references: [id])

  @@unique([userId, studyId, version])
}

enum ExportFormat {
  CSV
  JSON
}

model DataExport {
  id          String       @id @default(cuid())
  userId      String
  format      ExportFormat
  scope       Json // { studyId?, roomSlugs?, dateRange? }
  rowCount    Int?
  fileUrl     String?
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// Settings & telemetry
// ─────────────────────────────────────────────────────────────

model UserSettings {
  userId         String  @id
  reducedMotion  Boolean @default(false)
  highContrast   Boolean @default(false)
  largeText      Boolean @default(false)
  colorblindSafe Boolean @default(false)
  keyboardOnly   Boolean @default(false)
  sound          Boolean @default(true)
  hints          Boolean @default(true)
  language       String  @default("en")
  researchMode   Boolean @default(false)
  anonymousData  Boolean @default(true)
  shareAnalytics Boolean @default(true)
  notifications  Json    @default("{}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Product analytics event (page views, funnel steps). Not research data.
model AnalyticsEvent {
  id        BigInt   @id @default(autoincrement())
  userId    String?
  name      String
  props     Json?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
}
